<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDisplayName</key>
  <string>KolBo Message Filter</string>
  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleName</key>
  <string>$(PRODUCT_NAME)</string>
  <key>CFBundlePackageType</key>
  <string>XPC!</string>
  <key>CFBundleShortVersionString</key>
  <string>$(MARKETING_VERSION)</string>
  <key>CFBundleVersion</key>
  <string>$(CURRENT_PROJECT_VERSION)</string>
  <key>NSExtension</key>
  <dict>
    <!-- ILMessageFilterExtension point — unknown-sender SMS/MMS only. -->
    <key>NSExtensionPointIdentifier</key>
    <string>com.apple.identitylookup.message-filter</string>
    <key>NSExtensionPrincipalClass</key>
    <string>$(PRODUCT_MODULE_NAME).MessageFilterExtension</string>
    <key>NSExtensionAttributes</key>
    <dict>
      <!-- Optional network deferral target = KolBo's judge (PUBLIC host, NOT a secret — per COMMS contract).
           Only unknown-sender sender+body is sent; the per-enrollment token is NOT baked (rides the feed, .s). -->
      <key>ILMessageFilterExtensionNetworkURL</key>
      <string>https://text.kolbofilter.com:8443/ios-message-filter</string>
    </dict>
  </dict>
</dict>
</plist>
