<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Shared container so the filter can read enrollment config (tier, judge endpoint) the app stored.
       The Message Filter extension needs no special paid entitlement. -->
  <key>com.apple.security.application-groups</key>
  <array>
    <string>group.com.kolbo.shomer</string>
  </array>
</dict>
</plist>
